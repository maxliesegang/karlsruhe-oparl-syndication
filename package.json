{
  "name": "karlsruhe-oparl-syndication",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "smoke": "node --input-type=module --eval \"await Promise.all([import('./dist/api/http.js'), import('./dist/feed.js')])\"",
    "generate": "tsx src/index.ts",
    "validate:feed": "tsx src/validate-feed.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --project tests/tsconfig.json",
    "serve": "http-server ./docs -p 8080"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^24.13.3",
    "http-server": "^14.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "axios-retry": "^4.5.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.10.1",
    "feed": "^6.0.0",
    "pdf-parse": "^2.4.5"
  }
}
